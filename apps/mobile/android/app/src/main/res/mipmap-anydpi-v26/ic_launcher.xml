<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (all shipped devices are API 26+, so no pre-26
  bitmap variant is required beyond the fallback in mipmap-xxxhdpi). The
  foreground is the maskable Fabric mark, which is authored inside the
  adaptive safe zone; the background is the canonical brand purple.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
