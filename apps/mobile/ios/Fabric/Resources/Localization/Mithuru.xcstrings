        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මෙම භාෂාවට හඬ ලබාගත නොහැක. ඔබට ටයිප් කළ හැක."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த மொழிக்கு குரல் கிடைக்கவில்லை. தொடர்ந்து தட்டச்சு செய்யலாம்."
          }
        }
      }
    },
