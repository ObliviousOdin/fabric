# Derived output. The generic FabricMobile.xcodeproj and Fabric/Info.plist
# bootstrap files are committed because Xcode Cloud validates the project
# before post-clone scripts run. Regenerate both whenever project.yml changes.
DerivedData/
build/
*.xcuserstate
*.xcuserdatad/

# Local signing overrides (real team id / profiles) — never commit.
Signing.xcconfig
*.mobileprovision
*.p12
