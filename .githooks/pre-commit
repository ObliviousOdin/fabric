#!/bin/sh
# Reject commits made with a non-canonical or AI-tool git identity.
# Installed via: scripts/setup-git-guardrails.sh (sets core.hooksPath).
# Policy source of truth: scripts/commit_identity_audit.py
set -e
repo_root="$(git rev-parse --show-toplevel)"
exec python3 "$repo_root/scripts/commit_identity_audit.py" --check-config
