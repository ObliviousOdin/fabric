      "textMuted": "{color.violetCharcoal.textMuted}",
      "textDisabled": "{color.violetCharcoal.textDisabled}",
      "textOnBrand": "{color.base.white}",
      "border": "{color.violetCharcoal.border}",
      "borderStrong": "{color.violetCharcoal.borderStrong}",
      "action": "#5542E3",
