# License set: Apache-2.0 distribution license plus preserved third-party
# license texts (Hermes Agent MIT). LICENSE itself is auto-included.
include NOTICE
include THIRD_PARTY_NOTICES.md
graft LICENSES
graft skills
graft optional-skills
graft optional-mcps
graft locales
# The release workflow builds the dashboard before packaging. Keep the compiled
# SPA in source distributions so downstream wheel builds preserve web parity.
graft fabric_cli/web_dist
# The same release build produces the installable same-origin mobile PWA.
graft fabric_cli/mobile_web_dist
# Bundled plugin manifests (plugin.yaml / plugin.yml). Without these the
# PluginManager scan (fabric_cli/plugins.py) finds zero plugins on installs
# built from the sdist (e.g. Homebrew, downstream packagers). package-data
# below covers the wheel; this covers the sdist. See #34034 / #28149.
recursive-include plugins plugin.yaml plugin.yml
# Gateway assets include images plus YAML catalogs such as status_phrases.yaml.
recursive-include gateway/assets *
# First-party pet packages must also survive the sdist -> wheel path.
recursive-include agent/pet/assets *
global-exclude __pycache__
global-exclude *.py[cod]
