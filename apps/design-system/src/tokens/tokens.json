  "semantic": {
    "light": {
      "canvas": "{color.wovenWarm.canvas}",
      "surface": "{color.wovenWarm.surface}",
      "surfaceRaised": "{color.wovenWarm.surfaceRaised}",
      "surfaceInset": "{color.wovenWarm.surfaceInset}",
      "surfaceSubtle": "{color.wovenWarm.surface}",
      "surfaceCool": "{color.wovenWarm.surfaceInset}",
      "surfaceBrand": "{color.primary.25}",
      "text": "{color.wovenWarm.text}",
      "textMuted": "{color.wovenWarm.textMuted}",
      "textDisabled": "{color.wovenWarm.textDisabled}",
      "textOnBrand": "{color.base.white}",
      "border": "{color.wovenWarm.border}",
      "borderStrong": "{color.wovenWarm.borderStrong}",
