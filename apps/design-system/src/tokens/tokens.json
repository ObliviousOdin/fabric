      "thread": "{color.wovenWarm.thread}",
      "threadActive": "{color.primary.600}",
      "bracket": "{color.primary.600}"
    },
    "dark": {
      "canvas": "{color.violetCharcoal.canvas}",
      "surface": "{color.violetCharcoal.surface}",
      "surfaceRaised": "{color.violetCharcoal.surfaceRaised}",
      "surfaceInset": "{color.violetCharcoal.surfaceInset}",
      "surfaceSubtle": "{color.violetCharcoal.surface}",
      "surfaceCool": "{color.violetCharcoal.surfaceInset}",
