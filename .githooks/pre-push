#!/bin/sh
# Audit the actual outgoing commits (author, committer, message) before they
# leave the machine — catches commits created past the commit hooks
# (--no-verify, --author, GIT_AUTHOR_* overrides). Same code path as CI.
# Installed via: scripts/setup-git-guardrails.sh (sets core.hooksPath).
# Policy source of truth: scripts/commit_identity_audit.py
set -e
repo_root="$(git rev-parse --show-toplevel)"
exec python3 "$repo_root/scripts/commit_identity_audit.py" --pre-push
