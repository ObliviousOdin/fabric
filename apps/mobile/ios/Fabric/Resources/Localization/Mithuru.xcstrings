    "voiceIssueMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can keep typing. Check iPhone speech and microphone settings before trying voice again."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබට ටයිප් කළ හැක. නැවත හඬ උත්සාහ කිරීමට පෙර iPhone කථන සහ මයික්‍රොෆෝන සැකසුම් පරීක්ෂා කරන්න."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தொடர்ந்து தட்டச்சு செய்யலாம். குரலை மீண்டும் முயல்வதற்கு முன் iPhone பேச்சு மற்றும் ஒலிவாங்கி அமைப்புகளைச் சரிபார்க்கவும்."
          }
        }
      }
    },
