# ---------------------------------------------------------------------------
# Fabric hosted deploy — environment
#
# Copy to `.env` and edit the "Required" block, then run `./provision.sh`.
# This file is the Docker Compose env_file AND Compose's interpolation source.
#
# IMPORTANT: keep values on one line and free of `$` characters. The dashboard
# password hash and signing secret are written by provision.sh directly into
# `config.yaml` (not here) precisely because the scrypt hash contains `$`.
# ---------------------------------------------------------------------------

# ===== Required: edit these three =====

# Public domain that points (A/AAAA record) at this box. Caddy issues TLS for it.
FABRIC_PUBLIC_DOMAIN=agent.example.com

# Email for Let's Encrypt / ACME registration (expiry notices).
ACME_EMAIL=you@example.com

# One model-provider key. OpenRouter is the cheapest "just works" default and is
# enough on its own to make Fabric usable with no setup wizard. Swap for any
# provider key (ANTHROPIC_API_KEY, OPENAI_API_KEY, XAI_API_KEY, ...), or point at
# the compute broker below and leave this blank.
OPENROUTER_API_KEY=

# ===== Optional: point the model at a self-hosted / shared compute broker =====
# See docs: /deploy/compute-broker. When set, provision.sh writes a `custom`
# provider route into config.yaml instead of the OpenRouter default.
# FABRIC_MODEL_PROVIDER=custom
# FABRIC_MODEL_DEFAULT=your-frontier-model-id
# FABRIC_MODEL_BASE_URL=https://broker.example.com/v1
# BROKER_TENANT_KEY=

# ===== OpenAI-compatible API server (managed by provision.sh) =====
# Lets other apps use your agent as a backend with a bearer token.
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
# Generated by provision.sh (openssl rand -hex 32). Leave blank.
API_SERVER_KEY=

# ===== Host / runtime (auto-filled by provision.sh) =====
# UID/GID that owns the data dir so files created in the container stay writable
# on the host. provision.sh sets these to the current user if left blank.
FABRIC_UID=
FABRIC_GID=
# Where tenant state (== ~/.fabric) is persisted on the host.
FABRIC_DATA_DIR=./data
# Published image. Pin a tag for reproducible deploys.
FABRIC_IMAGE=ghcr.io/obliviousodin/fabric:latest
