  },
  "typography": {
    "family": {
      "sans": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
      "mono": "ui-monospace, 'SF Mono', 'Cascadia Mono', Menlo, Consolas, monospace"
    },
    "size": {
      "caption": "12px",
      "body": "14px",
      "emphasis": "16px",
      "subheading": "18px",
      "section": "20px",
      "heading": "24px",
      "pageTitle": "32px",
      "display": "48px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.1,
      "heading": 1.2,
      "label": 1.3,
      "body": 1.4
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "6": "24px",
    "8": "32px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "pill": "999px"
  },
  "controlHeight": {
    "sm": "32px",
    "md": "40px",
    "lg": "48px",
    "xl": "52px"
  },
  "density": {
    "compact": 0.875,
    "comfortable": 1
  },
  "motion": {
    "duration": {
      "instant": "100ms",
      "fast": "150ms",
      "base": "200ms",
      "slow": "300ms",
      "emphasis": "400ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.465, 0.183, 0.153, 0.946)"
    }
  }
}
