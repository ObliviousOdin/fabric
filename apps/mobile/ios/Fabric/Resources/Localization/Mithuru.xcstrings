{
  "sourceLanguage": "en",
  "strings": {
    "allowOnce": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes, allow once"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔව්, මෙවර පමණක්"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆம், ஒருமுறை அனுமதி"
          }
        }
      }
    },
    "allowOnlineSpeech": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow online speech"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "අන්තර්ජාල කථනයට ඉඩ දෙන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இணையப் பேச்சை அனுமதி"
          }
        }
      }
    },
    "appointments": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check appointments"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "හමුවීම් බලන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சந்திப்புகளைப் பார்"
          }
        }
      }
    },
    "back": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ආපසු"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பின்"
          }
        }
      }
    },
    "brand": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mithuru"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මිතුරු"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மிதுரு"
          }
        }
      }
    },
    "cancel": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "අවලංගු කරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ரத்து"
          }
        }
      }
    },
    "chooseDocument": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose document"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ලේඛනය තෝරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆவணத்தைத் தேர்ந்தெடு"
          }
        }
      }
    },
    "cloudExplanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you choose Yes, microphone audio may leave this iPhone for speech recognition. Fabric still sends only the text transcript to your paired gateway."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔව් තෝරාගත්තොත් කථනය හඳුනාගැනීමට මයික්‍රොෆෝන් හඬ මෙම iPhone එකෙන් පිටතට යා හැක. Fabric ඔබගේ gateway වෙත යවන්නේ පෙළ පමණි."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆம் என்றால் பேச்சை அறிய மைக்ரோஃபோன் ஒலி இந்த iPhone-ஐ விட்டு வெளியேறலாம். Fabric உங்கள் gateway-க்கு உரையை மட்டுமே அனுப்பும்."
          }
        }
      }
    },
    "cloudQuestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "May speech use Apple's online service when this iPhone cannot recognize the selected language on device?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මෙම iPhone එකේම හඳුනාගත නොහැකි විට Apple අන්තර්ජාල කථන සේවාව භාවිතා කළ හැකිද?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த iPhone-இல் மொழியை அறிய முடியாதபோது Apple இணையப் பேச்சுச் சேவையைப் பயன்படுத்தலாமா?"
          }
        }
      }
    },
    "confirmTitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please confirm"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "කරුණාකර තහවුරු කරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உறுதிப்படுத்துங்கள்"
          }
        }
      }
    },
    "connectionError": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I couldn't reach your Fabric. Check the connection and try again."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබගේ Fabric වෙත සම්බන්ධ විය නොහැකි විය. සම්බන්ධතාව පරීක්ෂා කර නැවත උත්සාහ කරන්න."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் Fabric-ஐ அணுக முடியவில்லை. இணைப்பைச் சரிபார்த்து மீண்டும் முயலுங்கள்."
          }
        }
      }
    },
    "conversationAccessibility": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mithuru conversation"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මිතුරු සංවාදය"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மிதுரு உரையாடல்"
          }
        }
      }
    },
    "deny": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No, do not do this"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "නැහැ, මෙය නොකරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இல்லை, இதைச் செய்யாதே"
          }
        }
      }
    },
    "disableOnlineSpeech": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn off online speech"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "අන්තර්ජාල කථනය අක්‍රිය කරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இணையப் பேச்சை நிறுத்து"
          }
        }
      }
    },
    "documentConsent": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This document may be sent to your paired Fabric gateway and the selected AI provider. Continue?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මෙම ලේඛනය ඔබගේ Fabric gateway සහ තෝරාගත් AI සේවාව වෙත යැවිය හැක. ඉදිරියට යන්නද?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த ஆவணம் உங்கள் Fabric gateway மற்றும் தேர்ந்தெடுத்த AI சேவைக்கு அனுப்பப்படலாம். தொடரவா?"
          }
        }
      }
    },
    "documentsToSend": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Documents to send"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "යැවීමට ඇති ලේඛන"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அனுப்ப வேண்டிய ஆவணங்கள்"
          }
        }
      }
    },
    "editTranscript": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Correct what I heard"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඇසූ දේ නිවැරදි කරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நான் கேட்டதைத் திருத்துங்கள்"
          }
        }
      }
    },
    "explainLetter": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explain a letter"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ලිපියක් පැහැදිලි කරන්න"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கடிதத்தை விளக்கு"
          }
        }
      }
    },
    "extraLarge": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extra large"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඉතා විශාල"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மிகப் பெரியது"
          }
        }
      }
    },
    "familyPrivacy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This choice only records that a helper is present. It does not create separate access to conversations, recordings, documents, messages, health information, or location."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මෙම තේරීම සහායකයෙකු සිටින බව පමණක් සටහන් කරයි. එය සංවාද, හඬ, ලේඛන, පණිවිඩ, සෞඛ්‍ය තොරතුරු හෝ ස්ථානයට වෙනම ප්‍රවේශයක් ලබා නොදේ."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்தத் தேர்வு உதவியாளர் இருப்பதை மட்டும் பதிவு செய்கிறது. உரையாடல்கள், குரல் பதிவுகள், ஆவணங்கள், செய்திகள், உடல்நலத் தகவல் அல்லது இருப்பிடத்திற்கு தனி அணுகலை வழங்காது."
          }
        }
      }
    },
    "familyQuestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Is a family member helping with setup?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "සැකසීමට පවුලේ කෙනෙක් උදව් කරනවාද?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அமைப்பில் குடும்ப உறுப்பினர் உதவுகிறாரா?"
          }
        }
      }
    },
    "greeting": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How can I help?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මම කෙසේ උදව් කරන්නද?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நான் எப்படி உதவலாம்?"
          }
        }
      }
    },
    "help": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Help"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "උදව්"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உதவி"
          }
        }
      }
    },
    "helpBody": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Talk, speak naturally, then correct the text if needed and tap Send. No wake word is used."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "කතා කරන්න ඔබා, ස්වභාවිකව කියන්න. අවශ්‍ය නම් පෙළ නිවැරදි කර යවන්න ඔබන්න. අවදි කිරීමේ වචනයක් නැත."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பேசுங்கள் என்பதைத் தொட்டு இயல்பாகப் பேசுங்கள். தேவையெனில் உரையைத் திருத்தி அனுப்பு என்பதைத் தொடுங்கள். விழிப்புச் சொல் இல்லை."
          }
        }
      }
    },
    "interactionQuestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Would you like to speak, type, or use both?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබ කතා කිරීමටද, ටයිප් කිරීමටද, දෙකමද කැමති?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பேசவா, தட்டச்சு செய்யவா, இரண்டுமா?"
          }
        }
      }
    },
    "languageQuestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Which language would you like?"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබ කැමති භාෂාව කුමක්ද?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "எந்த மொழியை விரும்புகிறீர்கள்?"
          }
        }
      }
    },
    "large": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Large"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "විශාල"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பெரியது"
          }
        }
      }
    },
    "listening": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Listening"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "අසමින්"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கேட்கிறேன்"
          }
        }
      }
    },
    "maximum": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximum"
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "උපරිම"
          }
        },
        "ta": {
