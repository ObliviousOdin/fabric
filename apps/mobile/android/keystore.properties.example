# Release signing for the Fabric Android client.
#
# Copy this file to `keystore.properties` (same directory as gradlew) and fill
# in the values, OR export the equivalent environment variables in CI. The
# real `keystore.properties` and any *.jks / *.keystore are gitignored — never
# commit signing material.
#
#   propertyKey    environment variable
#   -----------    --------------------------------
#   storeFile      FABRIC_ANDROID_KEYSTORE           (path to the .jks/.keystore)
#   storePassword  FABRIC_ANDROID_KEYSTORE_PASSWORD
#   keyAlias       FABRIC_ANDROID_KEY_ALIAS
#   keyPassword    FABRIC_ANDROID_KEY_PASSWORD
#
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore fabric-release.jks \
#     -alias fabric -keyalg RSA -keysize 2048 -validity 10000

storeFile=fabric-release.jks
storePassword=changeit
keyAlias=fabric
keyPassword=changeit
